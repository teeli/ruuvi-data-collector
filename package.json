{
  "name": "ruuvi-collector-v2",
  "version": "1.0.0",
  "description": "Collect measurements from RuuviTag & RuuviAir",
  "license": "MIT",
  "author": "Teemu Lahti",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "compile": "tsc",
    "start": "bun src/index.ts",
    "config:generate": "bun src/cli/commands/config-generate.ts",
    "watch": "bun --watch src/index.ts",
    "format": "prettier --write .",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:md": "markdownlint .",
    "lint:md:fix": "markdownlint --fix .",
    "test": "vitest",
    "prepare": "husky"
  },
  "dependencies": {
    "@influxdata/influxdb-client": "1.35.0",
    "@logtape/file": "2.2.4",
    "@logtape/logtape": "2.2.4",
    "@logtape/redaction": "2.2.4",
    "@stoprocent/noble": "2.5.5",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/node": "26.1.1",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "jiti": "2.7.0",
    "lint-staged": "17.0.8",
    "markdownlint-cli": "0.49.0",
    "oxlint": "1.73.0",
    "prettier": "3.9.5",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.10"
  },
  "peerDependencies": {
    "typescript": "5.9.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "bun run lint",
    "*.md": [
      "prettier --write",
      "markdownlint --fix"
    ]
  }
}
