{
  "name": "ruuvi-collector-v2",
  "version": "1.0.0",
  "description": "Collect measurements from RuuviTag & RuuviAir",
  "license": "MIT",
  "author": "Teemu Lahti",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "compile": "tsc",
    "start": "bun src/index.ts",
    "config:generate": "bun src/config/generate.ts",
    "watch": "bun --watch src/index.ts",
    "format": "prettier --write .",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "vitest",
    "prepare": "husky"
  },
  "dependencies": {
    "@influxdata/influxdb-client": "1.35.0",
    "@logtape/file": "^2.0.4",
    "@logtape/logtape": "^2.0.4",
    "@stoprocent/noble": "2.3.10",
    "dotenv": "17.3.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/bun": "1.3.10",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "jiti": "2.6.1",
    "lint-staged": "16.3.1",
    "oxlint": "1.50.0",
    "prettier": "3.8.1",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.0.18"
  },
  "peerDependencies": {
    "typescript": "5.9.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "bun run lint"
  }
}
